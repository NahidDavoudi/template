# NadStore — Apache config (React SPA, browser-style routes)

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite real files/directories (assets, uploads, api)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback: everything else → index.html
  RewriteRule . /index.html [L]
</IfModule>
